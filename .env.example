# ─────────────────────────────────────────────────────────────────────────────
# StakeGuard — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in values.
#
# ARCHITECTURE:
#   API (Railway)      → This project deployed as a standalone JSON API
#   Frontend (Vercel)  → Separate Next.js app that CALLS the API
#   Smart Contract     → Already deployed on Solana devnet
#
# The API has ZERO dependency on the frontend.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ─── Solana ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROGRAM_ID=Edmq5WTFJL5gtwMmD9HdtJ5N14ivXMP4vprvPxRkFZRJ

# ─── API Authentication ──────────────────────────────────────────────────────
# When set, all API endpoints (except /api/v1/docs) require X-API-Key header.
# External companies use this to authenticate with your hosted API.
# STAKEGUARD_API_KEY=your-secret-api-key

# ─── Custodial Mode ──────────────────────────────────────────────────────────
# Platform wallet for custodial escrow (non-crypto users).
# The API signs Solana transactions on behalf of fiat/credit users.
# Format: JSON array of 64 bytes from `solana-keygen new --outfile key.json`
# PLATFORM_WALLET_SECRET=[1,2,3,...,64]

# ─── Frontend → API Connection ───────────────────────────────────────────────
# Set this on the FRONTEND deployment (Vercel) to point to the API on Railway.
# Leave empty for local dev (same-origin).
# NEXT_PUBLIC_API_URL=https://stakeguard-api.up.railway.app

# Optional: API key for frontend to include in requests
# NEXT_PUBLIC_API_KEY=your-secret-api-key
