# ─────────────────────────────────────────────────────────────────────────────
# PackedPay Demo App — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in values.
#
# ARCHITECTURE:
#   API (api/ folder)  → Standalone Blink API (Supabase + Solana + Stripe)
#   Demo App (src/)    → This app. Uses the API exclusively. No backend deps.
#
# The demo app has ZERO dependency on Supabase, Stripe, or Anchor.
# It only talks to the Blink API.

# ─── Blink API Connection ────────────────────────────────────────────────
# Point to the running API instance:
#   Local dev:  http://localhost:3001
#   Production: https://blink-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: API key if the API requires X-API-Key header
# NEXT_PUBLIC_API_KEY=your-secret-api-key

# ─── Solana Wallet ────────────────────────────────────────────────────────────
# RPC endpoint for wallet adapter (transaction signing, balance checks)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
